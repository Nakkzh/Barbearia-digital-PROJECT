<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastrar Atendimento</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar" id="sidebar">
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">PRINCIPAL</div>
                    <a href="/user/index" class="nav-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
                        Dashboard
                    </a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">CAMPOS</div>
                    <div class="nav-collapsible" id="menuUsuarios">
                        <button class="nav-collapsible-toggle" onclick="toggleMenu('menuUsuarios')">
                            <div class="nav-item-content">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                Usuários
                            </div>
                            <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                        </button>
                        <div class="nav-collapsible-content">
                            <a href="/user/list" class="nav-subitem">Listar Usuários</a>
                            <a href="/user/create" class="nav-subitem">Cadastrar Usuário</a>
                        </div>
                    </div>
                    <div class="nav-collapsible" id="menuAtendimento">
                        <button class="nav-collapsible-toggle" onclick="toggleMenu('menuAtendimento')">
                            <div class="nav-item-content">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                                Atendimento
                            </div>
                            <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                        </button>
                        <div class="nav-collapsible-content">
                            <a href="/atendimento/list" class="nav-subitem">Listar Atendimentos</a>
                            <a href="/atendimento/create" class="nav-subitem">Cadastrar Atendimento</a>
                        </div>
                    </div>
                </div>
            </nav>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <div class="page-title">
                    <div>
                        <h1>Cadastrar Atendimento</h1>
                        <div class="breadcrumb">
                            <a href="/user/index">Início</a>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                            <span>Cadastrar Atendimento</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="container">
                <form id="formCadastro">
                    <div class="form-group">
                        <label for="nomeCliente">Nome do Cliente</label>
                        <input type="text" id="nomeCliente" placeholder="Digite o nome do cliente" required>
                    </div>
                    <div class="form-group">
                        <label for="telefone">Telefone</label>
                        <input type="tel" id="telefone" placeholder="Digite o telefone" required>
                    </div>
                    <div class="form-group">
                        <label for="dataNascimento">Data de Nascimento</label>
                        <input type="date" id="dataNascimento" required>
                    </div>
                    <div class="form-group">
                        <label for="dataAtendimento">Data do Atendimento</label>
                        <input type="date" id="dataAtendimento" required>
                    </div>
                    <div class="form-group">
                        <label for="horarioAtendimento">Horário do Atendimento</label>
                        <input type="time" id="horarioAtendimento" required>
                    </div>
                    <div class="form-group">
                        <label for="tipoServico">Tipo de Serviço</label>
                        <select id="tipoServico" required>
                            <option value="">Selecione o serviço</option>
                            <option value="corte_cabelo">Corte de Cabelo</option>
                            <option value="barba">Barba</option>
                            <option value="sobrancelha">Sobrancelha</option>
                            <option value="outros">Outros</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="profissional">Profissional</label>
                        <input type="text" id="profissional" placeholder="Digite o nome do profissional" required>
                    </div>
                    <div class="mt-24 flex gap-16">
                        <a href="/atendimento/list" class="btn btn-secondary">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                            Voltar
                        </a>
                        <button type="submit" class="btn btn-primary" style="flex: 1;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>
                            Cadastrar Atendimento
                        </button>
                    </div>
                </form>
                <div id="alertContainer" class="mt-24"></div>
            </div>
        </main>
    </div>

    <script>
        function toggleMenu(menuId) {
            document.getElementById(menuId).classList.toggle('open');
        }

        (function() {
            const path = window.location.pathname;
            document.querySelectorAll('.nav-collapsible-toggle').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.nav-collapsible').forEach(m => m.classList.remove('open'));
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));

            if (path === '/user/index' || path === '/') {
                document.querySelector('a[href="/user/index"]')?.classList.add('active');
            } else if (path.startsWith('/user/')) {
                const menu = document.getElementById('menuUsuarios');
                menu?.classList.add('open');
                menu?.querySelector('.nav-collapsible-toggle')?.classList.add('active');
            } else if (path.startsWith('/atendimento/')) {
                const menu = document.getElementById('menuAtendimento');
                menu?.classList.add('open');
                menu?.querySelector('.nav-collapsible-toggle')?.classList.add('active');
            }
        })();

        document.getElementById('formCadastro').addEventListener('submit', async (e) => {
            e.preventDefault();
            const alertContainer = document.getElementById('alertContainer');
            const dados = {
                nomeCliente: document.getElementById('nomeCliente').value,
                telefone: document.getElementById('telefone').value,
                dataNascimento: document.getElementById('dataNascimento').value,
                dataAtendimento: document.getElementById('dataAtendimento').value,
                horarioAtendimento: document.getElementById('horarioAtendimento').value,
                tipoServico: document.getElementById('tipoServico').value,
                profissional: document.getElementById('profissional').value
            };

            try {
                const response = await fetch('/atendimento/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dados)
                });
                const data = await response.json();

                if (response.ok) {
                    alertContainer.innerHTML = `<div class="alert alert-success"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg><span>Atendimento cadastrado com sucesso!</span></div>`;
                    e.target.reset();
                } else {
                    alertContainer.innerHTML = `<div class="alert alert-error"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg><span>Erro ao cadastrar: ${data.message || 'Tente novamente.'}</span></div>`;
                }
            } catch (error) {
                alertContainer.innerHTML = `<div class="alert alert-error"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg><span>Erro ao conectar com o servidor.</span></div>`;
            }
        });
    </script>
</body>
</html>