<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Atendimentos</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar" id="sidebar">
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">PRINCIPAL</div>
                    <a href="/user/index" class="nav-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>
                        </svg>
                        Dashboard
                    </a>
                </div>
        
                <div class="nav-section">
                    <div class="nav-section-title">CAMPOS</div>
                    
                    <div class="nav-collapsible" id="menuUsuarios">
                        <button class="nav-collapsible-toggle" onclick="toggleMenu('menuUsuarios')">
                            <div class="nav-item-content">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                </svg>
                                Usuários
                            </div>
                            <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m6 9 6 6 6-6"/>
                            </svg>
                        </button>
                        <div class="nav-collapsible-content">
                            <a href="/user/list" class="nav-subitem">Listar Usuários</a>
                            <a href="/user/create" class="nav-subitem">Cadastrar Usuário</a>
                        </div>
                    </div>
        
                    <div class="nav-collapsible" id="menuAtendimento">
                        <button class="nav-collapsible-toggle" onclick="toggleMenu('menuAtendimento')">
                            <div class="nav-item-content">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
                                </svg>
                                Atendimento
                            </div>
                            <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m6 9 6 6 6-6"/>
                            </svg>
                        </button>
                        <div class="nav-collapsible-content">
                            <a href="/atendimento/list" class="nav-subitem">Listar Atendimentos</a>
                            <a href="/atendimento/create" class="nav-subitem">Cadastrar Atendimento</a>
                        </div>
                    </div>
                </div>
            </nav>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <div class="page-title">
                    <div>
                        <h1>Lista de Atendimentos</h1>
                        <div class="breadcrumb">
                            <a href="/atendimento/index">Início</a>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m9 18 6-6-6-6"/>
                            </svg>
                            <span>Lista de Atendimentos</span>
                        </div>
                    </div>
                </div>
                <a href="/atendimento/create" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"/><path d="M12 5v14"/>
                    </svg>
                    Novo Atendimento
                </a>
            </div>

            <div class="table-container">
                <div class="table-header">
                    <div class="table-search">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                        </svg>
                        <input type="search" id="searchInput" placeholder="Buscar atendimentos...">
                    </div>
                    <button class="btn btn-ghost btn-sm" onclick="location.reload()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/>
                        </svg>
                        Atualizar
                    </button>
                </div>

                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Telefone</th>
                            <th>Nascimento</th>
                            <th>Data</th>
                            <th>Horário</th>
                            <th>Serviço</th>
                            <th>Profissional</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody id="atendimentoTableBody">
                        <% for(atendimento of atendimentos) { %>
                            <tr>
                                <td><%= atendimento.id %></td>
                                <td><strong><%= atendimento.nomeCliente %></strong></td>
                                <td><%= atendimento.telefone %></td>
                                <td><%= atendimento.dataNascimento %></td>
                                <td><%= atendimento.dataAtendimento %></td>
                                <td><%= atendimento.horarioAtendimento %></td>
                                <td><%= atendimento.tipoServico %></td>
                                <td><%= atendimento.profissional %></td>
                                <td class="actions">
                                    <a href="/atendimento/edit/<%= atendimento.id %>" class="btn btn-secondary btn-sm">
                                        Editar
                                    </a>
                                    <button onclick="apagarAtendimento('<%= atendimento.id %>')" class="btn btn-danger btn-sm">
                                        Apagar
                                    </button>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script>
        // Menu Toggle
        function toggleMenu(menuId) {
            const menu = document.getElementById(menuId);
            menu.classList.toggle('open');
        }

        // Deleção de Atendimento
        async function apagarAtendimento(id) {
            if (!confirm('Tem certeza que deseja apagar este atendimento?')) return;
            try {
                const response = await fetch('/atendimento/' + id, { 
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                if (response.ok) {
                    location.reload();
                } else {
                    alert('Erro ao apagar atendimento: ' + (data.message || 'Tente novamente.'));
                }
            } catch (error) {
                console.error('Erro:', error);
                alert('Erro ao conectar com o servidor');
            }
        }

        // Busca na Tabela
        const searchInput = document.getElementById('searchInput');
        searchInput.addEventListener('input', (e) => {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#atendimentoTableBody tr');
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });

        // Gestão de estado Ativo no Menu (Baseado na URL)
        const currentPath = window.location.pathname;
        document.querySelectorAll('.nav-collapsible-toggle, .nav-item').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.nav-collapsible').forEach(el => el.classList.remove('open'));

        if (currentPath === '/user/index' || currentPath === '/') {
            document.querySelector('a[href="/user/index"]')?.classList.add('active');
        } else if (currentPath.startsWith('/user/')) {
            const menu = document.getElementById('menuUsuarios');
            menu?.classList.add('open');
            menu?.querySelector('.nav-collapsible-toggle')?.classList.add('active');
        } else if (currentPath.startsWith('/atendimento/')) {
            const menu = document.getElementById('menuAtendimento');
            menu?.classList.add('open');
            menu?.querySelector('.nav-collapsible-toggle')?.classList.add('active');
        }
    </script>
</body>
</html>